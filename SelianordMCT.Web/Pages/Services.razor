@page "/services"

<PageTitle>Services | Selianord MCT</PageTitle>

<section class="page-hero">
    <div class="container">
        <p class="section-tag">Services</p>
        <h1>Professional Services</h1>
        <p class="page-subtitle">
            Microsoft training, software development, and learning content solutions
            tailored for individuals, institutions, and organisations.
        </p>
    </div>
</section>

<section class="section">
    <div class="container card-grid">
        <div class="service-card">
            <h3>Corporate Training</h3>
            <p>
                Instructor-led Microsoft and IT training for businesses, teams, and departments.
                Delivery can be customised to organisational goals and skill levels.
            </p>
        </div>

        <div class="service-card">
            <h3>Site Training</h3>
            <p>
                Practical on-site delivery for colleges, campuses, training centres, and institutions
                that require hands-on guided learning experiences.
            </p>
        </div>

        <div class="service-card">
            <h3>Software Development</h3>
            <p>
                Design and development of web applications, APIs, dashboards, Azure-based solutions,
                and business systems using Microsoft technologies.
            </p>
        </div>

        <div class="service-card">
            <h3>Learning Content Development</h3>
            <p>
                Development of learner guides, slide decks, practical activities, assessments,
                rubrics, and technical documentation for training delivery.
            </p>
        </div>
    </div>
</section>