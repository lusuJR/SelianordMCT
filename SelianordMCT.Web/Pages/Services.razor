@page "/services"

<PageTitle>Services | Selianord MCT</PageTitle>

<section class="page-hero">
    <div class="container">
        <p class="section-tag">Services</p>
        <h1>Professional Services</h1>
        <p class="page-subtitle">
            Microsoft training, software development, and learning content solutions
            tailored for individuals, institutions, and organisations.
        </p>
    </div>
</section>

<section class="section">
    <div class="container service-grid">
        <div class="service-card">
            <h3>Corporate Training</h3>
            <p>
                Instructor-led Microsoft and IT training for businesses, teams, and departments.
                Delivery is customised to organisational goals, team roles, and skill levels.
            </p>
        </div>

        <div class="service-card">
            <h3>Site Training</h3>
            <p>
                Practical on-site delivery for colleges, campuses, training centres, and institutions
                that require guided hands-on learning experiences.
            </p>
        </div>

        <div class="service-card">
            <h3>Software Development</h3>
            <p>
                Design and development of web applications, APIs, dashboards, Azure-based solutions,
                and business systems using Microsoft technologies.
            </p>
        </div>

        <div class="service-card">
            <h3>Learning Content Development</h3>
            <p>
                Development of learner guides, slide decks, practical activities, assessments,
                rubrics, and technical documentation for training delivery.
            </p>
        </div>
    </div>
</section>

<section class="section section-soft">
    <div class="container">
        <div class="section-header">
            <p class="section-tag">Who I Support</p>
            <h2>Designed for Real Learning and Business Needs</h2>
        </div>

        <div class="service-audience-grid">
            <div class="about-card">
                <h3>Businesses and Teams</h3>
                <p>
                    Training solutions designed to upskill staff, strengthen cloud capabilities,
                    and support digital transformation initiatives.
                </p>
            </div>

            <div class="about-card">
                <h3>Academic Institutions</h3>
                <p>
                    Practical training, curriculum support, assessments, and learning resources
                    aligned with modern teaching and technical delivery needs.
                </p>
            </div>

            <div class="about-card">
                <h3>Private Learners</h3>
                <p>
                    Support for learners seeking certification preparation, practical development skills,
                    and structured learning guidance.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-header">
            <p class="section-tag">How I Work</p>
            <h2>Structured, Practical, Results-Focused</h2>
        </div>

        <div class="service-process-grid">
            <div class="process-card">
                <div class="process-number">01</div>
                <h3>Understand the Need</h3>
                <p>
                    I begin by understanding the business, training, or learning objective clearly.
                </p>
            </div>

            <div class="process-card">
                <div class="process-number">02</div>
                <h3>Design the Right Solution</h3>
                <p>
                    The training, content, or technical solution is shaped around practical outcomes.
                </p>
            </div>

            <div class="process-card">
                <div class="process-number">03</div>
                <h3>Deliver with Impact</h3>
                <p>
                    Delivery focuses on clarity, relevance, and real-world application.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="section cta-section">
    <div class="container cta-content">
        <h2>Need training or digital support for your organisation?</h2>
        <p>
            Let’s discuss the right service for your team, learners, or project goals.
        </p>
        <a href="/contact" class="btn btn-primary">Request Training Quote</a>
    </div>
</section>