@page "/courses"

<PageTitle>Courses | Selianord MCT</PageTitle>

<section class="page-hero">
    <div class="container">
        <p class="section-tag">Courses</p>
        <h1>Training Areas</h1>
        <p class="page-subtitle">
            Explore Microsoft and technology-focused training programmes designed to build practical,
            industry-ready skills.
        </p>
    </div>
</section>

<section class="section">
    <div class="container course-grid">
        <div class="service-card">
            <h3>Azure Training</h3>
            <p>
                Training in Azure fundamentals, administration, development, and cloud solution design.
            </p>
        </div>

        <div class="service-card">
            <h3>Developer Training</h3>
            <p>
                Application development, APIs, C#, ASP.NET Core, Blazor, and DevOps-aligned skills.
            </p>
        </div>

        <div class="service-card">
            <h3>Data & AI</h3>
            <p>
                Data fundamentals, database systems, analytics, reporting, and AI solution foundations.
            </p>
        </div>

        <div class="service-card">
            <h3>Power Platform</h3>
            <p>
                Power BI, Power Apps, Power Automate, and business process automation training.
            </p>
        </div>

        <div class="service-card">
            <h3>Security Training</h3>
            <p>
                Microsoft security fundamentals, identity concepts, governance, and compliance topics.
            </p>
        </div>

        <div class="service-card">
            <h3>Custom Training Programmes</h3>
            <p>
                Tailored training programmes developed around business, academic, or project-specific needs.
            </p>
        </div>
    </div>
</section>