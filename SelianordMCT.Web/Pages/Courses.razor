@page "/courses"

<PageTitle>Courses | Selianord MCT</PageTitle>

<section class="page-hero">
    <div class="container">
        <p class="section-tag">Courses</p>
        <h1>Training Areas</h1>
        <p class="page-subtitle">
            Explore Microsoft and technology-focused training programmes designed to build practical,
            industry-ready skills for learners, teams, and institutions.
        </p>
    </div>
</section>

<section class="section">
    <div class="container course-grid">
        <div class="service-card">
            <h3>Azure Training</h3>
            <p>
                Training in Azure fundamentals, administration, development, and cloud solution design.
            </p>
        </div>

        <div class="service-card">
            <h3>Developer Training</h3>
            <p>
                Application development, APIs, C#, ASP.NET Core, Blazor, and DevOps-aligned skills.
            </p>
        </div>

        <div class="service-card">
            <h3>Data & AI</h3>
            <p>
                Data fundamentals, database systems, analytics, reporting, and AI solution foundations.
            </p>
        </div>

        <div class="service-card">
            <h3>Power Platform</h3>
            <p>
                Power BI, Power Apps, Power Automate, and business process automation training.
            </p>
        </div>

        <div class="service-card">
            <h3>Security Training</h3>
            <p>
                Microsoft security fundamentals, identity concepts, governance, and compliance topics.
            </p>
        </div>

        <div class="service-card">
            <h3>Custom Training Programmes</h3>
            <p>
                Tailored training programmes built around specific organisational, academic, or project needs.
            </p>
        </div>
    </div>
</section>

<section class="section section-soft">
    <div class="container">
        <div class="section-header">
            <p class="section-tag">Delivery Options</p>
            <h2>Flexible Learning Formats</h2>
        </div>

        <div class="service-audience-grid">
            <div class="about-card">
                <h3>Instructor-Led Training</h3>
                <p>
                    Live sessions delivered in a guided, practical format for stronger engagement and understanding.
                </p>
            </div>

            <div class="about-card">
                <h3>On-Site Delivery</h3>
                <p>
                    Training delivered at institutions, campuses, or business locations for direct team support.
                </p>
            </div>

            <div class="about-card">
                <h3>Custom Learning Support</h3>
                <p>
                    Content, examples, and focus areas adapted to learner needs, curriculum outcomes, or business goals.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-header">
            <p class="section-tag">Who These Courses Are For</p>
            <h2>Built for Learners, Teams, and Institutions</h2>
        </div>

        <div class="service-process-grid">
            <div class="process-card">
                <div class="process-number">01</div>
                <h3>Private Learners</h3>
                <p>
                    Individuals seeking certification preparation, practical cloud skills, or development knowledge.
                </p>
            </div>

            <div class="process-card">
                <div class="process-number">02</div>
                <h3>Academic Institutions</h3>
                <p>
                    Colleges and training providers looking for structured, curriculum-aligned technical delivery.
                </p>
            </div>

            <div class="process-card">
                <div class="process-number">03</div>
                <h3>Corporate Teams</h3>
                <p>
                    Organisations investing in staff skills development, cloud readiness, and digital growth.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="section cta-section">
    <div class="container cta-content">
        <h2>Looking for the right training programme?</h2>
        <p>
            Let’s discuss the best course or custom training path for your learners, team, or institution.
        </p>
        <a href="/contact" class="btn btn-primary">Request Training Quote</a>
    </div>
</section>