@page "/"

<PageTitle>Selianord MCT</PageTitle>

<section class="hero-section">
    <div class="container hero-grid">

        <div class="hero-text">
            <p class="eyebrow">Microsoft Certified Trainer</p>

            <h1 class="hero-title">
                Lusukama Selemani, MCT
            </h1>

            <p class="hero-subtitle">
                Empowering individuals and organisations through Microsoft training,
                software development, and digital learning solutions.
            </p>

            <div class="hero-actions">
                <a href="/contact" class="btn btn-primary">Request Training Quote</a>
                <a href="/courses" class="btn btn-outline">Explore Training Areas</a>
            </div>
        </div>

        <div class="hero-image-wrapper" >
           

            <img src="images/selemani-mct.png"
                 class="hero-image"
                 alt="Lusukama Selemani Microsoft Certified Trainer" />

            <p class="hero-caption">
                Microsoft Partner Network Trainer Environment
            </p>

        </div>
        <div class="hero-badges">

            <span class="badge">MCT Certified</span>

            <span class="badge">Azure Instructor</span>

            <span class="badge">Software Developer</span>

        </div>

    </div>
    
</section>


<section class="section">

    <div class="container section-header">

        <p class="section-tag">Services</p>

        <h2>
            What I Offer
        </h2>

        <p>
            Professional training, learning solutions, and software development services.
        </p>

    </div>


    <div class="container card-grid">

        <div class="service-card">

            <h3>Corporate Training</h3>

            <p>
                Microsoft certification training for organisations and teams.
            </p>

        </div>


        <div class="service-card">

            <h3>Site Training</h3>

            <p>
                Practical on-site delivery for colleges and institutions.
            </p>

        </div>


        <div class="service-card">

            <h3>Software Development</h3>

            <p>
                Web systems, APIs, Azure solutions and automation platforms.
            </p>

        </div>


        <div class="service-card">

            <h3>Learning Content Development</h3>

            <p>
                Learner guides, assessments, slides and curriculum design.
            </p>

        </div>

    </div>

</section>
<section class="trust-section">
    <div class="container trust-grid">

        <div>
            <h3>Microsoft Certified Trainer</h3>
            <p>
                Official Microsoft training aligned with certification pathways and real-world implementation skills.
            </p>
        </div>

        <div>
            <h3>Industry Experience</h3>
            <p>
                Experience supporting students, institutions, and organisations with cloud and software development training.
            </p>
        </div>

        <div>
            <h3>Curriculum Specialist</h3>
            <p>
                Development of structured learning material, assessments, and technical training resources.
            </p>
        </div>

    </div>
</section>
<div class="container section-header">
    <p class="section-tag">Professional Credentials</p>
    <h2>Recognised Expertise</h2>
</div>
<section class="cert-strip">

    <div class="container section-header">
        <p class="section-tag">Professional Credentials</p>
        <h2>Recognised Expertise</h2>
    </div>

    <div class="container cert-grid">

        <div class="cert-card">
            <div class="cert-icon">🎓</div>
            <strong>Microsoft Certified Trainer</strong>
            <span>Official Microsoft training delivery</span>
        </div>

        <div class="cert-card">
            <div class="cert-icon">☁️</div>
            <strong>Azure Instructor</strong>
            <span>Cloud solution training specialist</span>
        </div>

        <div class="cert-card">
            <div class="cert-icon">💻</div>
            <strong>Software Developer</strong>
            <span>Web, APIs & enterprise solutions</span>
        </div>

        <div class="cert-card">
            <div class="cert-icon">📘</div>
            <strong>Learning Content Specialist</strong>
            <span>Curriculum & assessment design</span>
        </div>

    </div>

</section>