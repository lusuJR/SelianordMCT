@page "/contact"

<PageTitle>Contact | Selianord MCT</PageTitle>

<section class="page-hero">
    <div class="container">
        <p class="section-tag">Contact</p>
        <h1>Let’s Work Together</h1>
        <p class="page-subtitle">
            Reach out for training bookings, software development enquiries,
            learning content support, or collaboration opportunities.
        </p>
    </div>
</section>

<section class="section">
    <div class="container contact-grid">
        <div class="contact-card">
            <h3>Contact Information</h3>
            <p><strong>Name:</strong> Lusukama Selemani</p>
            <p><strong>Role:</strong> Microsoft Certified Trainer</p>
            <p><strong>Email:</strong> your-email@example.com</p>
            <p><strong>Phone:</strong> +27 xx xxx xxxx</p>
            <p><strong>Location:</strong> South Africa</p>
        </div>

        <div class="contact-card">
            <h3>Send an Enquiry</h3>

            <div class="form-group">
                <label>Full Name</label>
                <input class="form-input" placeholder="Enter your full name" />
            </div>

            <div class="form-group">
                <label>Email Address</label>
                <input class="form-input" placeholder="Enter your email address" />
            </div>

            <div class="form-group">
                <label>Subject</label>
                <input class="form-input" placeholder="Enter the subject" />
            </div>

            <div class="form-group">
                <label>Message</label>
                <textarea class="form-input form-textarea" placeholder="Enter your message"></textarea>
            </div>

            <button class="btn btn-primary">Send Enquiry</button>
        </div>
    </div>
</section>