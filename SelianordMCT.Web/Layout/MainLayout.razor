@using SelianordMCT.Web.Services
@inject AuthService AuthService
@inject NavigationManager Nav
@inherits LayoutComponentBase

<header class="top-navbar">
    <div class="container nav-container">

        <div class="brand">
            <span class="brand-title">Selianord MCT</span>
            <span class="brand-subtitle">Microsoft Certified Trainer</span>
        </div>

        <nav class="nav-links">
            <NavLink href="/" Match="NavLinkMatch.All">Home</NavLink>
            <NavLink href="/about">About</NavLink>
            <NavLink href="/services">Services</NavLink>
            <NavLink href="/courses">Courses</NavLink>
            <NavLink href="/portfolio">Portfolio</NavLink>
            <NavLink href="/contact">Contact</NavLink>
        </nav>

        <div class="nav-actions">
            @if (isAuthenticated)
            {
                <NavLink href="/admin/enquiries" class="btn btn-outline">
                    Admin Dashboard
                </NavLink>

                <button type="button" class="btn btn-outline" @onclick="Logout">
                    Logout
                </button>
            }
            else
            {
                <NavLink href="/login" class="btn btn-outline">
                    Admin Login
                </NavLink>
            }

            <a href="/contact" class="btn btn-primary">
                Request Training Quote
            </a>
        </div>

    </div>
</header>

<main>
    @Body
</main>

<footer class="footer">
    <div class="container footer-grid">

        <div class="footer-brand">
            <h3>Selianord MCT</h3>
            <p>Microsoft Certified Trainer</p>
            <p>
                Practical Microsoft training, software development,
                and learning content solutions.
            </p>
        </div>

        <div>
            <h4>Quick Links</h4>
            <ul class="footer-links">
                <li><a href="/">Home</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/services">Services</a></li>
                <li><a href="/courses">Courses</a></li>
                <li><a href="/portfolio">Portfolio</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>
        </div>

        <div>
            <h4>Services</h4>
            <ul class="footer-links">
                <li>Microsoft Training</li>
                <li>Corporate Training</li>
                <li>Software Development</li>
                <li>Learning Content Development</li>
            </ul>
        </div>

        <div>
            <h4>Contact</h4>
            <ul class="footer-links">
                <li>South Africa</li>
                <li>selianordev@gmail.com</li>
                <li>+27 61 581 7580</li>
            </ul>
        </div>

    </div>

    <div class="footer-bottom">
        <div class="container">
            © @DateTime.Now.Year Selianord MCT — Microsoft Certified Trainer. All rights reserved.
        </div>
    </div>
</footer>

@code {
    private bool isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        isAuthenticated = await AuthService.IsAuthenticatedAsync();
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        isAuthenticated = false;
        Nav.NavigateTo("/");
    }
}